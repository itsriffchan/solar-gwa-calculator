{
    "manifest_version": 3,
    "name": "Solar GWA Calculator",
    "version": "1.0",
    "description": "Automatically calculate GWA",
    "permissions": ["activeTab", "scripting"],
    "icon": {
        "48": "assets/icons/icon48.png",
        "128": "assets/icons/icon128.png"
    },
    "action": {
        "default_popup": "src/popup/popup.html",
        "default_title": "Calculate GWA",
        "default_icon": {
            "48": "assets/icons/icon48.png",
            "128": "assets/icons/icon128.png"
        }
    },
    "host_permissions": ["https://solar.feutech.edu.ph/*"]
}